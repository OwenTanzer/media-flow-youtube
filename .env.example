# --- Required ---

# The Google Drive folder where transcripts are stored. This should be a
# normal folder owned by the same Google account that produced the OAuth
# credentials below - no sharing step needed, since the app authenticates
# as that account directly.
DRIVE_FOLDER_ID=

# OAuth 2.0 credentials authorizing the app to act as your own Google
# account (NOT a service account - service accounts have zero Drive
# storage quota and cannot create new files in a personal Drive folder).
# Run `python get_refresh_token.py` once locally to obtain these -
# see README.md for the full walkthrough.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Shared secret required in the `X-API-Key` header for /transcripts and
# /batch/run. Required unless DRY_RUN=true - the app refuses to start
# without it, since the deployed URL is otherwise public and unauthenticated.
API_KEY=

# --- Optional ---

# Comma-separated transcript language preference, in priority order.
TRANSCRIPT_LANGUAGES=en

# If true, skips all real Drive API calls and logs what would happen.
# Useful for local testing without credentials.
DRY_RUN=false

# Run the Drive-queue batch job on a schedule inside this same process
# (an alternative to deploying batch_runner.py as a separate Railway Cron
# Job service).
ENABLE_SCHEDULER=false

# Standard 5-field crontab expression, UTC. Only used when
# ENABLE_SCHEDULER=true. Example: every day at 06:00 UTC.
SCHEDULE_CRON=0 6 * * *

# How old (in seconds) the advisory lock discover_and_process.py holds
# during a run must be before a new invocation will treat it as a crashed
# prior run and proceed anyway, rather than exiting to avoid overlapping
# writes to queue.json/_index.json. Should comfortably exceed how long a
# full discover-and-process run normally takes.
DISCOVERY_LOCK_TTL_SECONDS=1800

# How many hours a discovered video (e.g. an in-progress livestream, or one
# YouTube hasn't finished auto-captioning yet) keeps being retried after a
# "no captions" result before it's treated as permanent and dropped from
# the queue. Only applies to videos discovered via discover_and_process.py
# - manually-added queue.json entries get no grace period.
NO_CAPTIONS_GRACE_HOURS=24

# A continuous run of many back-to-back requests measurably degrades the
# rotating proxy pool's success rate over the course of the run (observed
# empirically). Above this many entries, run_batch() processes the queue
# in chunks of this size with a real cooldown (BATCH_COOLDOWN_SECONDS)
# between chunks instead of burning through it all in one burst. At or
# below this size, processing is unpaced as before.
BATCH_SIZE_THRESHOLD=10

# Cooldown (in seconds) between chunks once BATCH_SIZE_THRESHOLD is
# exceeded. 5 minutes was long enough in testing to fully recover a
# degraded pool's success rate back to baseline; much shorter cooldowns
# (e.g. 20s) only partially helped.
BATCH_COOLDOWN_SECONDS=300

# Egress proxy for outbound YouTube requests. Cloud hosts (Railway
# included) are frequently IP-blocked by YouTube; if you see
# "status": "blocked" responses, configure one of the two options below.
# Leave unset to make requests directly (no proxy).
#
# "webshare": a rotating proxy provider with a free tier and first-class
#             support in youtube-transcript-api. Get credentials at
#             https://dashboard.webshare.io/proxy/settings after signing
#             up. Note: the free tier is datacenter IPs, which may still
#             get blocked - the paid "Residential" tier is the reliable fix.
# "generic":  any HTTP/HTTPS proxy you already have, including a
#             self-hosted tunnel back to your own residential IP.
YOUTUBE_PROXY_TYPE=

# Used when YOUTUBE_PROXY_TYPE=webshare.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Optional comma-separated country codes to restrict the IP pool to
# (reduces latency, or works around location-based restrictions).
WEBSHARE_PROXY_LOCATIONS=

# Used when YOUTUBE_PROXY_TYPE=generic. At least one is required; the
# proxy URL should include credentials if the proxy needs them, e.g.
# http://user:pass@host:port
YOUTUBE_PROXY_HTTP_URL=
YOUTUBE_PROXY_HTTPS_URL=

# --- Transcript summarization (optional) ---
# Turns each successfully-archived transcript into a structured, timestamped
# JSON insight artifact (summaries/<video_id>.json in the Drive folder) via
# Claude. Runs as the final stage of discover_and_process.py - see README's
# "Transcript summarization" section. Not read by the web service.

# Resolved automatically by the Anthropic SDK - required for summarization
# to run at all. Set only in Railway's environment variables (or a local,
# gitignored .env) - never commit it.
ANTHROPIC_API_KEY=

# Claude model used for summarization. Any model ID that supports
# structured outputs (see the Anthropic docs) works; Haiku is the
# recommended low-cost default.
SUMMARY_MODEL=claude-haiku-4-5

# Output token ceiling per summarization call.
SUMMARY_MAX_OUTPUT_TOKENS=4096

# Transcript-length policy: if the transcript body (captions only, frontmatter
# stripped) exceeds this many characters, it's truncated to this length before
# being sent to the model, and the resulting summary artifact is flagged with
# "transcript_truncated": true. Points and timestamps within the retained
# portion stay accurate; content past the cutoff is simply not covered. This
# is a deliberate v1 simplification (explicit truncation, not multi-pass
# chunking-and-merging) - 400K characters comfortably covers a multi-hour
# video's transcript.
SUMMARY_MAX_TRANSCRIPT_CHARS=400000

# Per-run cost/throughput controls: discover_and_process.py stops
# summarizing (leaving the rest for the next scheduled run) as soon as any
# one of these is reached.
SUMMARY_MAX_VIDEOS_PER_RUN=20
SUMMARY_MAX_TOTAL_TOKENS_PER_RUN=500000
SUMMARY_MAX_COST_USD_PER_RUN=2.0
