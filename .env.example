# --- Required ---

# The Google Drive folder where transcripts are stored. This should be a
# normal folder owned by the same Google account that produced the OAuth
# credentials below - no sharing step needed, since the app authenticates
# as that account directly.
DRIVE_FOLDER_ID=

# OAuth 2.0 credentials authorizing the app to act as your own Google
# account (NOT a service account - service accounts have zero Drive
# storage quota and cannot create new files in a personal Drive folder).
# Run `python get_refresh_token.py` once locally to obtain these -
# see README.md for the full walkthrough.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Shared secret required in the `X-API-Key` header for /transcripts and
# /batch/run. Required unless DRY_RUN=true - the app refuses to start
# without it, since the deployed URL is otherwise public and unauthenticated.
API_KEY=

# --- Optional ---

# Comma-separated transcript language preference, in priority order.
TRANSCRIPT_LANGUAGES=en

# If true, skips all real Drive API calls and logs what would happen.
# Useful for local testing without credentials.
DRY_RUN=false

# Run the Drive-queue batch job on a schedule inside this same process
# (an alternative to deploying batch_runner.py as a separate Railway Cron
# Job service).
ENABLE_SCHEDULER=false

# Standard 5-field crontab expression, UTC. Only used when
# ENABLE_SCHEDULER=true. Example: every day at 06:00 UTC.
SCHEDULE_CRON=0 6 * * *

# How old (in seconds) the advisory lock discover_and_process.py holds
# during a run must be before a new invocation will treat it as a crashed
# prior run and proceed anyway, rather than exiting to avoid overlapping
# writes to queue.json/_index.json. Should comfortably exceed how long a
# full discover-and-process run normally takes.
DISCOVERY_LOCK_TTL_SECONDS=1800

# How many hours a discovered video (e.g. an in-progress livestream, or one
# YouTube hasn't finished auto-captioning yet) keeps being retried after a
# "no captions" result before it's treated as permanent and dropped from
# the queue. Only applies to videos discovered via discover_and_process.py
# - manually-added queue.json entries get no grace period.
NO_CAPTIONS_GRACE_HOURS=24

# Above this many entries, run_batch() processes the queue in chunks of
# this size, checkpointing queue.json after each chunk rather than only
# at the end. This exists for crash-safety on large runs (a long run that
# dies partway through doesn't lose already-processed progress) - it is
# NOT a proxy-pool-recovery mechanism (see BATCH_COOLDOWN_SECONDS below;
# testing showed the pool doesn't actually need "resting"). At or below
# this size, processing is unchunked as before.
BATCH_SIZE_THRESHOLD=10

# Cooldown (in seconds) between chunks once BATCH_SIZE_THRESHOLD is
# exceeded. Originally defaulted to 300 on the assumption that a
# continuous run degrades the rotating proxy pool's success rate and
# needs time to recover. Controlled testing disproved this: a fresh,
# uncooled single request against a known-failing video succeeded at
# roughly the same ~80% rate as one taken after a 5-minute gap - the
# per-request failure rate is a fairly constant property of the pool
# (some fraction of exit IPs are already flagged by YouTube at any given
# moment), not something that accumulates with our own volume or recovers
# with a wait. TRANSCRIPT_FETCH_MAX_ATTEMPTS (below) is what actually
# addresses this. Chunking's only remaining job is checkpointing progress
# for crash-safety, which doesn't require sleeping - defaults to 0. Only
# raise this if independent evidence shows a nonzero delay helps; a large
# queue with both a nonzero cooldown and retries can idle for a long time
# without one.
BATCH_COOLDOWN_SECONDS=0

# How many times to retry a single transcript fetch when it hits a
# blocked/network-flaky response, before giving up for this run (the
# video stays in the queue and is retried on the next scheduled run
# either way). Each attempt uses a brand-new client instance - a fresh
# connection, and thus another independent draw from the rotating proxy
# pool - since a blocked draw is roughly an independent ~15-20% chance
# per attempt: 2-3 fresh draws pushes effective success into the high
# 90s%. Confirmed empirically against videos that had actually failed in
# a live run - most succeeded on the very next fresh attempt.
TRANSCRIPT_FETCH_MAX_ATTEMPTS=3

# Egress proxy for outbound YouTube requests. Cloud hosts (Railway
# included) are frequently IP-blocked by YouTube; if you see
# "status": "blocked" responses, configure one of the two options below.
# Leave unset to make requests directly (no proxy).
#
# "webshare": a rotating proxy provider with a free tier and first-class
#             support in youtube-transcript-api. Get credentials at
#             https://dashboard.webshare.io/proxy/settings after signing
#             up. Note: the free tier is datacenter IPs, which may still
#             get blocked - the paid "Residential" tier is the reliable fix.
# "generic":  any HTTP/HTTPS proxy you already have, including a
#             self-hosted tunnel back to your own residential IP.
YOUTUBE_PROXY_TYPE=

# Used when YOUTUBE_PROXY_TYPE=webshare.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Optional comma-separated country codes to restrict the IP pool to
# (reduces latency, or works around location-based restrictions).
WEBSHARE_PROXY_LOCATIONS=

# Used when YOUTUBE_PROXY_TYPE=generic. At least one is required; the
# proxy URL should include credentials if the proxy needs them, e.g.
# http://user:pass@host:port
YOUTUBE_PROXY_HTTP_URL=
YOUTUBE_PROXY_HTTPS_URL=

# --- Transcript summarization (optional) ---
# Turns each successfully-archived transcript into a structured, timestamped
# JSON insight artifact (summaries/<video_id>.json in the Drive folder) via
# Claude. Runs as the final stage of discover_and_process.py - see README's
# "Transcript summarization" section. Not read by the web service.

# Resolved automatically by the Anthropic SDK - required for summarization
# to run at all. If unset, the summarization stage is skipped cleanly
# (logged, not an error) rather than failing discover_and_process.py's
# whole run - this stage is genuinely optional. Set only in Railway's
# environment variables (or a local, gitignored .env) - never commit it.
ANTHROPIC_API_KEY=

# Claude model used for summarization. Must have a pricing entry in
# app/summarize.py's PRICING_PER_MTOK_USD (the app refuses to start
# otherwise - an unrecognized model would make estimate_cost_usd() return
# None and silently disable SUMMARY_MAX_COST_USD_PER_RUN enforcement). Haiku
# is the recommended low-cost default.
SUMMARY_MODEL=claude-haiku-4-5

# Output token ceiling per summarization call.
SUMMARY_MAX_OUTPUT_TOKENS=4096

# Transcript-length policy: the idempotency hash always covers the complete
# transcript body (so a real change is never invisible just because it falls
# past the cutoff below), but if that body exceeds this many characters, only
# the first SUMMARY_MAX_TRANSCRIPT_CHARS of it is sent to the model, and the
# resulting summary artifact is flagged with "transcript_truncated": true.
# Points and timestamps within the retained portion stay accurate; content
# past the cutoff is simply not covered. This is a deliberate v1
# simplification (explicit truncation, not multi-pass chunking-and-merging)
# - 400K characters comfortably covers a multi-hour video's transcript.
SUMMARY_MAX_TRANSCRIPT_CHARS=400000

# Per-run cost/throughput controls: discover_and_process.py stops
# summarizing (leaving the rest for the next scheduled run) as soon as any
# one of these is reached. Each call's worst-case cost/tokens are reserved
# against these caps *before* the call is made, not just checked against
# totals from completed calls - the input side is a real pre-flight count
# via Anthropic's token-counting endpoint (covering the system prompt and
# output schema, not just the transcript), and the output side treats
# SUMMARY_MAX_OUTPUT_TOKENS as fully consumed - so a single call starting
# just under a cap can't push the run well past it. A video whose own
# worst case exceeds the entire cap by itself is skipped rather than
# blocking the rest of the backlog forever; see README's "Cost controls"
# section for the distinction.
SUMMARY_MAX_VIDEOS_PER_RUN=20
SUMMARY_MAX_TOTAL_TOKENS_PER_RUN=500000
SUMMARY_MAX_COST_USD_PER_RUN=2.0

# How many attempts a single video gets across runs before a persistent
# failure is treated as permanent and stops being retried (until its
# transcript hash, SUMMARY_MODEL, or the prompt version changes, which
# resets the count as a fresh unit of work). A failure classified as
# non-retryable (e.g. a safety refusal - deterministic for the same input)
# stops being retried immediately, regardless of this cap. A genuine
# auth/credential failure is handled separately, before any video is
# touched at all - see README.
SUMMARY_MAX_ATTEMPTS_PER_VIDEO=3

# How long (in seconds) a retryable per-video failure waits before it's
# eligible to be retried again, recorded as each failed attempt's
# "next_retry_at". Without this, a transient failure would otherwise be
# retried again on the very next invocation regardless of how recently it
# just failed.
SUMMARY_RETRY_BACKOFF_SECONDS=900

# --- Insight dashboard (optional) ---
# vidproc_app.py - the Streamlit dashboard over the summary archive (issue
# #8). Deliberately public/unauthenticated (no API_KEY-equivalent gate,
# unlike the web service above), since it's meant to be a publicly
# viewable dashboard. Reuses DRIVE_FOLDER_ID and the Google OAuth
# credentials above (read-only) - no new required credentials.

# How long (in seconds) a loaded snapshot of channels/videos/summaries is
# cached per Streamlit session before a fresh read from Drive. Data only
# changes on discover_and_process.py's own cron cycle (hours), so this
# just caps Drive API calls per viewer session - a Refresh button in the
# header bypasses it on demand.
VIDPROC_CACHE_TTL_SECONDS=300
