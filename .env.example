# --- Required ---

# The Google Drive folder where transcripts are stored. Share this folder
# (Editor access) with the service account's client_email before use.
DRIVE_FOLDER_ID=

# Full JSON key for a Google Cloud service account with Drive API access,
# either as raw JSON on one line or base64-encoded (base64 avoids quoting
# issues in most host UIs, e.g.: base64 -w0 service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Shared secret required in the `X-API-Key` header for /transcripts and
# /batch/run. Required unless DRY_RUN=true - the app refuses to start
# without it, since the deployed URL is otherwise public and unauthenticated.
API_KEY=

# --- Optional ---

# Comma-separated transcript language preference, in priority order.
TRANSCRIPT_LANGUAGES=en

# If true, skips all real Drive API calls and logs what would happen.
# Useful for local testing without credentials.
DRY_RUN=false

# Run the Drive-queue batch job on a schedule inside this same process
# (an alternative to deploying batch_runner.py as a separate Railway Cron
# Job service).
ENABLE_SCHEDULER=false

# Standard 5-field crontab expression, UTC. Only used when
# ENABLE_SCHEDULER=true. Example: every day at 06:00 UTC.
SCHEDULE_CRON=0 6 * * *
